# Cloudflare Worker deployment
WORKER_NAME=spotify-discord-control
PUBLIC_BASE_URL=https://spotify-discord-control.YOUR_SUBDOMAIN.workers.dev
# Optional if you already created a KV namespace:
# KV_NAMESPACE_ID=

# Spotify app credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
# PKCE does not require a client secret. Set only if your app uses one.
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_PATH=/spotify/callback
# Optional explicit redirect URI. If omitted, PUBLIC_BASE_URL + SPOTIFY_REDIRECT_PATH is used.
# SPOTIFY_REDIRECT_URI=https://spotify-discord-control.YOUR_SUBDOMAIN.workers.dev/spotify/callback

# Discord app/bot credentials
DISCORD_APPLICATION_ID=your_discord_application_id
DISCORD_PUBLIC_KEY=your_discord_public_key
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id
# Optional: guild commands update instantly while testing. Omit for global commands.
# DISCORD_GUILD_ID=your_test_server_id
