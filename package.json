{
  "name": "spotify-discord-control",
  "version": "0.1.0",
  "private": false,
  "description": "Small Spotify OAuth PKCE CLI with optional Discord playback controls.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "spotify-oauth": "./src/bin/spotify-oauth.ts",
    "spotify-discord-bot": "./src/bin/spotify-discord-bot.ts"
  },
  "scripts": {
    "bootstrap": "scripts/bootstrap-oss.sh",
    "serve": "bun run src/bin/spotify-oauth.ts serve",
    "discord": "bun run src/bin/spotify-discord-bot.ts",
    "deploy:worker": "scripts/deploy-worker.sh",
    "register:discord": "bun run scripts/register-discord-commands.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3",
    "wrangler": "^4.96.0"
  }
}
